<Window x:Class="TaskSchedulerPro.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Scheduler Pro (C# Frontend)"
        Height="600" Width="900"
        Background="#FF121212"
        Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Task Scheduler Pro"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,12,0"/>
            <TextBlock Text="C# Frontend · Python Backend"
                       VerticalAlignment="Center"
                       Opacity="0.7"/>
            <Button Content="Refresh"
                    Width="80"
                    Margin="24,0,0,0"
                    Click="Refresh_Click"/>
        </StackPanel>

        <!-- Task list -->
        <DataGrid x:Name="TasksGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*"/>
                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <TextBox x:Name="NewTaskTitleTextBox"
                     Width="250"
                     Margin="0,0,8,0"
                     PlaceholderText="New task title..."/>
            <Button Content="Add Task"
                    Width="100"
                    Click="AddTask_Click"/>
            <TextBlock x:Name="StatusTextBlock"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Opacity="0.8"/>
        </StackPanel>
    </Grid>
</Window>

